# Hugging Face Token (required for gated datasets like ViHSD)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Optional: Weights & Biases for experiment tracking
# WANDB_API_KEY=your_wandb_key_here

# Optional: Custom paths
# DATA_DIR=./data
# MODEL_DIR=./models
# RESULTS_DIR=./results

# Environment notes:
# - Python 3.11 recommended
# - PyTorch 2.2.x (latest available for macOS MPS)
# - transformers <5.0 required for PyTorch 2.2.x compatibility
